{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoicePicker",
  "version": "0.1.0",
  "identifier": "com.voicepicker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VoicePicker - 设置",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "exceptionDomain": "",
      "signingIdentity": null,
      "hardenedRuntime": false
    }
  },
  "plugins": {
    "globalShortcut": {
      "shortcuts": [
        {
          "key": "X",
          "modifiers": ["Cmd", "Option"],
          "action": "readSelectedText"
        }
      ]
    }
  }
}
